# Single .env file for both local and production
# ---------------------------------------------
# Use _LOCAL and _PROD suffixes; the app picks by NODE_ENV.
# Prisma CLI (migrate, generate) only reads DATABASE_URL — set it for the environment you're in.
#
# LOCAL (your machine): set DATABASE_URL = same as DATABASE_URL_LOCAL (so prisma migrate works).
# PRODUCTION (VPS):     set DATABASE_URL = same as DATABASE_URL_PROD (so prisma migrate works on deploy).

# --- Local (your machine) ---
PORT_LOCAL=4000
DATABASE_URL_LOCAL="postgresql://huzaifa:YOUR_PASSWORD@localhost:5432/probashicv?schema=public"
# For Prisma CLI locally (optional if you set DATABASE_URL below):
# DATABASE_URL="postgresql://huzaifa:YOUR_PASSWORD@localhost:5432/probashicv?schema=public"
JWT_SECRET_LOCAL="dev-secret"
OPENAI_API_KEY_LOCAL=
FRONTEND_URL_LOCAL="http://localhost:5173"

# --- Production (VPS / cv.divsketch.com) ---
NODE_ENV=production
PORT_PROD=4000
DATABASE_URL_PROD="postgresql://user:password@localhost:5432/probashicv?schema=public"
# For Prisma CLI on server (required for deploy): same as DATABASE_URL_PROD
# DATABASE_URL="postgresql://user:password@localhost:5432/probashicv?schema=public"
JWT_SECRET_PROD="use-openssl-rand-base64-32"
OPENAI_API_KEY_PROD=
FRONTEND_URL_PROD="https://cv.divsketch.com"
